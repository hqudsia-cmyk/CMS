@page "{id:int}"
@model CMS.Web.Pages.Admin.Menu.DeleteModel
@{
    ViewData["Title"] = "Delete Menu Item";
}

<div class="container mt-4">
    <h1>Delete Menu Item</h1>
    <hr />
    <div class="alert alert-danger">
        Are you sure you want to delete <strong>@Model.ItemTitle</strong>?
    </div>
    <form method="post">
        <input type="hidden" name="id" value="@Model.ItemId" />
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a href="/Admin/Menu" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>
