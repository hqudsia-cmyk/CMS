@page
@model CMS.Web.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-12">
            <h1>Admin Dashboard</h1>
            <p class="text-muted">Manage your CMS content</p>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Pages</h5>
                    <p class="card-text">Total Pages: <strong>@Model.TotalPages</strong></p>
                    <a href="/Admin/Pages" class="btn btn-primary btn-sm">Manage Pages</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Menu Items</h5>
                    <p class="card-text">Total Menu Items: <strong>@Model.TotalMenuItems</strong></p>
                    <a href="/Admin/Menu" class="btn btn-primary btn-sm">Manage Menu</a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Styles</h5>
                    <p class="card-text">Customize CSS for content elements</p>
                    <a href="/Admin/Styles" class="btn btn-primary btn-sm">Manage Styles</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Settings</h5>
                    <p class="card-text">Configure your site settings</p>
                    <a href="/Admin/Settings" class="btn btn-primary btn-sm">Settings</a>
                </div>
            </div>
        </div>
    </div>
</div>
