@page
@model CMS.Web.Pages.Admin.MenuModel
@{
    ViewData["Title"] = "Manage Menu";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1>Menu Items</h1>
            <a href="/Admin/Menu/Create" class="btn btn-success">Add Menu Item</a>
        </div>
    </div>

    @if (Model.MenuItems != null && Model.MenuItems.Any())
    {
        <div class="table-responsive">
            <table class="table table-striped">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Slug</th>
                        <th>Order</th>
                        <th>Visible</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.MenuItems)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.Slug</td>
                            <td>@item.Order</td>
                            <td>
                                @if (item.IsVisible)
                                {
                                    <span class="badge bg-success">Visible</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Hidden</span>
                                }
                            </td>
                            <td>
                                <a href="/Admin/Menu/Edit/@item.Id" class="btn btn-sm btn-primary">Edit</a>
                                <a href="/Admin/Menu/Delete/@item.Id" class="btn btn-sm btn-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No menu items yet. <a href="/Admin/Menu/Create">Create one now</a></div>
    }
</div>
